# 環境識別（重要 / 誤デプロイ防止の中核）
# production | demo | local。各 Vercel プロジェクトで必ず設定する。
#   本番プロジェクト → production / demo プロジェクト → demo / 手元 → local（未設定でも local 扱い）
# NEXT_PUBLIC_ なのでビルド時に焼き込まれる（demo バナー表示・整合チェックに使用）。
NEXT_PUBLIC_APP_ENV=local

# この環境が指すべき Firebase プロジェクトID（任意だが強く推奨）
# FIREBASE_PROJECT_ID と一致しなければ起動/ビルドを失敗させる（環境取り違えの検出）。
# 各 Vercel プロジェクトに一度だけ、その環境の正しいプロジェクトIDを設定する。
EXPECTED_FIREBASE_PROJECT_ID=your-firebase-project-id

# LINE LIFF
# LINE Developers Console > 各 LIFF アプリの LIFF ID
# エンドポイント URL に ?env=dev / ?env=review / ?env=prod を付与して判定
NEXT_PUBLIC_LIFF_ID=YOUR_DEV_LIFF_ID
NEXT_PUBLIC_LIFF_ID_REVIEW=YOUR_REVIEW_LIFF_ID
NEXT_PUBLIC_LIFF_ID_PROD=YOUR_PROD_LIFF_ID

# LINE Messaging API
# LINE Developers Console > Messaging API チャネル
LINE_CHANNEL_ACCESS_TOKEN=YOUR_CHANNEL_ACCESS_TOKEN
LINE_CHANNEL_SECRET=YOUR_CHANNEL_SECRET

# Google OAuth（管理者ログイン・本番）
NEXT_PUBLIC_GOOGLE_OAUTH_CLIENT_ID=YOUR_GOOGLE_OAUTH_CLIENT_ID
ADMIN_EMAILS=admin@example.com
# 管理者パスワードログイン（dev/staging 専用 / 本番では設定しない）
# 非本番では Google OAuth の代わりにこのパスワード一本でログイン可。
# 本番ビルドにこの値があると prebuild で失敗する。
ADMIN_SIMPLE_PASSWORD=

# Google Calendar
# GCP > IAM > サービスアカウント
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
# サービスアカウントの秘密鍵（JSON の private_key の値をそのまま貼る）
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nXXXX\n-----END RSA PRIVATE KEY-----\n"

# Google Calendar ID（各施設のカレンダー ID）
CALENDAR_ID_MEETINGROOM_A=your-calendar-id@group.calendar.google.com
CALENDAR_ID_MEETINGROOM_B=your-calendar-id@group.calendar.google.com
CALENDAR_ID_MEETINGROOM_C=your-calendar-id@group.calendar.google.com
CALENDAR_ID_BOOTH_1=your-calendar-id@group.calendar.google.com
CALENDAR_ID_BOOTH_2=your-calendar-id@group.calendar.google.com
CALENDAR_ID_BOOTH_3=your-calendar-id@group.calendar.google.com

# Firebase
# Firebase Console > プロジェクト設定 > サービスアカウント > Admin SDK
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-firebase-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nXXXX\n-----END RSA PRIVATE KEY-----\n"
FIREBASE_STORAGE_BUCKET=your-firebase-project.appspot.com

# セッション
# JWT 署名用シークレット（必須 / 最低32文字のランダム文字列）
# 生成例: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=YOUR_SESSION_SECRET_AT_LEAST_32_CHARS

# 管理者 CSRF 許可オリジン（カンマ区切り、本番ドメインを設定）
ADMIN_ALLOWED_ORIGINS=https://admin.example.com

# ドメイン
# ドメインベースルーティング用（未設定時は制限なし）
CUSTOMER_DOMAIN=portal.example.com
ADMIN_DOMAIN=admin.example.com

# Cron
# Vercel Cron Job の認証トークン（必須）
# 生成例: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=YOUR_CRON_SECRET

# Square 決済（現在未使用 — 決済機能は無効化中。将来用に残しています）
# SQUARE_ACCESS_TOKEN=YOUR_SQUARE_ACCESS_TOKEN
# SQUARE_LOCATION_ID=YOUR_SQUARE_LOCATION_ID
# SQUARE_ENVIRONMENT=sandbox
# NEXT_PUBLIC_SQUARE_APPLICATION_ID=YOUR_SQUARE_APPLICATION_ID

# Resend（招待メール送信）
# https://resend.com/api-keys で取得
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 送信元アドレス（省略時: noreply@eightbase.net）
# RESEND_FROM_ADDRESS=noreply@eightbase.net

# ダミーデータ（dev/staging 専用 / 本番では設定しない）
# on のとき各 GET API がモックデータを返す。プレビューモードとは独立。
# 本番ビルドにこの値があると prebuild で失敗する。
EIGHTBASE_DUMMY_DATA=

# プレビューモード
# 本番では原則未設定。必要な場合も書き込み API は許可されません。
PREVIEW_SECRET=YOUR_PREVIEW_SECRET
REVIEW_LINE_USER_ID=review-user
REVIEW_LINE_DISPLAY_NAME=LINE審査ユーザー

# ポータル URL
# LINE 通知メッセージ内のリンクに使用される顧客向けアプリの URL
NEXT_PUBLIC_PORTAL_URL=https://portal.example.com
