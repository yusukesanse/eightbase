rules_version = '2';
// ⚠️ Emulator 専用の全許可ルール。**本番には絶対にデプロイしないこと。**
// 統合テストは Admin SDK（ルールを迂回）で動くため、このルールは firebase.json が
// firestore 設定を要求するためだけの最小ファイル。本番ルールとは別物。
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
